# ══════════════════════════════════════════════════════════════════════════════
# L'ÉTUDIANT SALONS — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE
# ----------
# 1. Copy this file:   cp .env.example .env.local
# 2. Fill in every value from your Supabase project dashboard:
#    https://supabase.com/dashboard/project/<YOUR_PROJECT_REF>/settings/api
# 3. NEVER commit .env.local — it is already in .gitignore
#
# LOCAL DEV  → values here point to Supabase Cloud (no local Supabase needed)
# PRODUCTION → set the same vars in Vercel Dashboard > Settings > Environment Variables
# ══════════════════════════════════════════════════════════════════════════════


# ── Supabase — Public (safe to expose to the browser) ─────────────────────────
# Found in: Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Found in: Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Supabase — Secret (server-side only, never exposed to the browser) ─────────
# Found in: Dashboard > Settings > API > Project API keys > service_role
# ⚠️  DANGER: this key bypasses Row Level Security. Never use in client code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Found in: Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here


# ── PostgreSQL Direct Connection (optional) ────────────────────────────────────
# Only needed for raw SQL scripts, migrations via psql, or Prisma.
# NOT used by the Next.js app at runtime — Supabase client handles all queries.
#
# Found in: Dashboard > Settings > Database > Connection string > URI (Pooling)
POSTGRES_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true

# Found in: Dashboard > Settings > Database > Connection string > URI (Direct)
POSTGRES_URL_NON_POOLING=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres


# ── Google OAuth (optional — only if Google sign-in is enabled) ────────────────
# Set these in Supabase Dashboard > Authentication > Providers > Google
# AND in Google Cloud Console > APIs & Credentials > OAuth 2.0 Client IDs
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# ── WAX / Eventmaker API (optional) ───────────────────────────────────────────
# EVENTMAKER_API_KEY=
# WAX_API_KEY=
